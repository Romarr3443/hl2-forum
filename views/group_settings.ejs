<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Настройки группы: <%= group.name %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .settings-container { max-width: 800px; margin: 20px auto; padding: 20px; }
        .settings-section { background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px; margin-bottom: 20px; }
        .role-card { display: flex; align-items: center; justify-content: space-between; padding: 10px; background: rgba(255,255,255,0.05); margin-bottom: 8px; border-radius: 8px; }
        .member-card { display: flex; align-items: center; gap: 10px; padding: 8px; background: rgba(255,255,255,0.03); margin-bottom: 5px; border-radius: 5px; }
        .member-card img { width: 30px; height: 30px; border-radius: 50%; }
        .delete-btn { background: #ff4444; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer; }
    </style>
</head>
<body>
    <nav class="sidebar">
        <div class="sidebar-icon-logo">🛡️</div>
        <ul class="nav-list">
            <li class="nav-item"><a href="/" class="nav-link"><span class="nav-icon">🏠</span><span class="nav-text">Главная</span></a></li>
            <li class="nav-item"><a href="/groups" class="nav-link"><span class="nav-icon">👥</span><span class="nav-text">Группы</span></a></li>
            <li class="nav-item"><a href="/group/<%= group.id %>" class="nav-link"><span class="nav-icon">💬</span><span class="nav-text">Чат группы</span></a></li>
            <li class="nav-item"><a href="/logout" class="nav-link logout-btn"><span class="nav-icon">🚪</span><span class="nav-text">Выход</span></a></li>
        </ul>
    </nav>

    <div class="container">
        <header>
            <h1><a href="/">Half-Life 2 Fan Forum</a></h1>
            <div class="user-menu">
                <img src="<%= user.avatar %>" width="30">
                <a href="/user/<%= user.id %>"><%= user.username %></a>
            </div>
        </header>

        <div class="settings-container">
            <div class="settings-section">
                <h2>⚙️ Настройки группы: <%= group.name %></h2>
                <form action="/group/<%= group.id %>/update" method="POST">
                    <label>Название группы:</label>
                    <input type="text" name="name" value="<%= group.name %>" required>
                    <label style="display:flex;align-items:center;gap:5px;margin:10px 0;">
                        <input type="checkbox" name="is_public" value="1" <%= group.is_public ? 'checked' : '' %> style="width:auto;">
                        Открытая группа (видна всем)
                    </label>
                    <button type="submit">💾 Сохранить</button>
                </form>
            </div>

            <div class="settings-section">
                <h2>🎭 Роли группы</h2>
                <div id="roles-list">
                    <% if (roles && roles.length > 0) { %>
                        <% roles.forEach(function(role) { %>
                            <div class="role-card" style="border-left:4px solid <%= role.color || '#fff' %>;">
                                <strong style="color:<%= role.color || '#fff' %>;"><%= role.name %></strong>
                                <button class="delete-btn" onclick="deleteRole(<%= role.id %>)">🗑️</button>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p style="color:#888;">Нет ролей. Создайте первую!</p>
                    <% } %>
                </div>
                
                <h3>Создать роль</h3>
                <form id="create-role-form" style="display:flex;gap:10px;align-items:end;flex-wrap:wrap;">
                    <div><label>Название:</label><input type="text" id="role-name" required></div>
                    <div><label>Цвет:</label><input type="color" id="role-color" value="#ff9900"></div>
                    <button type="submit">➕ Создать</button>
                </form>
            </div>

            <div class="settings-section">
                <h2>👥 Участники (<%= members ? members.length : 0 %>)</h2>
                <% if (members && members.length > 0) { %>
                    <% members.forEach(function(member) { %>
                        <div class="member-card">
                            <img src="<%= member.avatar || '/images/default_avatar.png' %>" alt="<%= member.username %>">
                            <span><a href="/user/<%= member.user_id %>"><%= member.username %></a></span>
                            <% if (member.user_id == group.creator_id) { %><span style="color:#ff9900;">👑</span><% } %>
                            <select onchange="assignRole(<%= member.user_id %>, this.value)" style="margin-left:auto;padding:5px;background:#333;color:white;border:1px solid #555;border-radius:3px;">
                                <option value="">Без роли</option>
                                <% if (roles) { roles.forEach(function(role) { %>
                                    <option value="<%= role.id %>" <%= member.role_id == role.id ? 'selected' : '' %>><%= role.name %></option>
                                <% }); } %>
                            </select>
                            <% if (member.user_id != group.creator_id) { %>
                                <button class="delete-btn" onclick="kickMember(<%= member.user_id %>)">🚫</button>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('create-role-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            const name = document.getElementById('role-name').value;
            const color = document.getElementById('role-color').value;
            const r = await fetch('/api/group/<%= group.id %>/create-role', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, color })
            });
            const d = await r.json();
            if (d.success) window.location.reload();
            else alert('Ошибка');
        });

        async function deleteRole(roleId) {
            if (!confirm('Удалить роль?')) return;
            await fetch('/api/group/<%= group.id %>/delete-role', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roleId })
            });
            window.location.reload();
        }

        async function assignRole(userId, roleId) {
            await fetch('/api/group/<%= group.id %>/assign-role', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId, roleId })
            });
        }

        async function kickMember(userId) {
            if (!confirm('Выгнать участника?')) return;
            await fetch('/api/group/<%= group.id %>/kick', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId })
            });
            window.location.reload();
        }
    </script>
</body>
</html>
