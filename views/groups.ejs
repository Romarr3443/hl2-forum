<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Группы</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .groups-container { max-width: 800px; margin: 20px auto; padding: 20px; }
        .group-card { display: flex; align-items: center; gap: 15px; padding: 15px; background: rgba(0,0,0,0.5); border-radius: 10px; margin-bottom: 15px; cursor: pointer; transition: all 0.4s; border: 1px solid rgba(255,255,255,0.1); }
        .group-card:hover { transform: translateX(10px); border-color: #ff9900; box-shadow: 0 10px 30px rgba(255,153,0,0.3); }
        .group-card img { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; border: 2px solid #ff9900; }
        .group-info { flex: 1; }
        .group-info h3 { margin: 0; color: #ff9900; }
        .group-info p { margin: 5px 0; color: #888; }
        .public-badge { background: #4CAF50; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.7em; }
        .private-badge { background: #ff9900; color: black; padding: 2px 8px; border-radius: 10px; font-size: 0.7em; }
        .create-group-section { background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px; margin-bottom: 20px; }
        .create-group-section form { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
        .create-group-section input { flex: 1; min-width: 200px; }
        .invites-section { margin-top: 30px; background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px; }
        .invite-item { display: flex; align-items: center; justify-content: space-between; padding: 10px; background: rgba(255,255,255,0.05); margin-bottom: 10px; border-radius: 5px; }
        .accept-btn { background: #4CAF50; color: white; border: none; padding: 5px 15px; border-radius: 3px; cursor: pointer; margin-left: 5px; }
        .reject-btn { background: #ff6b6b; color: white; border: none; padding: 5px 15px; border-radius: 3px; cursor: pointer; margin-left: 5px; }
        .creator-badge { color: #ff9900; font-size: 0.8em; }
    </style>
</head>
<body>
    <nav class="sidebar">
        <div class="sidebar-icon-logo">🛡️</div>
        <div class="sidebar-logo">HL2 Forum</div>
        <ul class="nav-list">
            <li class="nav-item"><a href="/" class="nav-link"><span class="nav-icon">🏠</span><span class="nav-text">Главная</span></a></li>
            <li class="nav-item"><a href="/new" class="nav-link create-btn"><span class="nav-icon">✏️</span><span class="nav-text">Создать тему</span></a></li>
            <li class="nav-item"><a href="/chat" class="nav-link"><span class="nav-icon">💬</span><span class="nav-text">Общий чат</span></a></li>
            <li class="nav-item"><a href="/groups" class="nav-link active"><span class="nav-icon">👥</span><span class="nav-text">Группы</span></a></li>
            <li class="nav-item"><a href="/dialogs" class="nav-link"><span class="nav-icon">📨</span><span class="nav-text">Диалоги</span></a></li>
            <li class="nav-item"><a href="/support" class="nav-link"><span class="nav-icon">🆘</span><span class="nav-text">Поддержка</span></a></li>
            <div class="nav-divider"></div>
            <% if (user) { %>
                <li class="nav-item"><a href="/user/<%= user.id %>" class="nav-link"><span class="nav-icon">👤</span><span class="nav-text">Профиль</span></a></li>
                <% if (['founder','admin','support','moderator'].includes(user.role)) { %>
                    <li class="nav-item"><a href="/admin" class="nav-link" style="color:#ff9900;"><span class="nav-icon">⚙️</span><span class="nav-text">Админ-панель</span></a></li>
                <% } %>
                <li class="nav-item"><a href="/logout" class="nav-link logout-btn"><span class="nav-icon">🚪</span><span class="nav-text">Выход</span></a></li>
            <% } %>
        </ul>
    </nav>

    <div class="container">
        <header>
            <h1><a href="/">Half-Life 2 Fan Forum</a></h1>
            <div class="user-menu">
                <img src="<%= user.avatar %>" width="30">
                <a href="/user/<%= user.id %>"><%= user.username %></a>
            </div>
        </header>

        <div class="groups-container">
            <div class="create-group-section">
                <h2>Создать новую группу</h2>
                <form action="/create-group" method="POST">
                    <input type="text" name="name" placeholder="Название группы" required>
                    <label style="display:flex;align-items:center;gap:5px;color:white;white-space:nowrap;">
                        <input type="checkbox" name="is_public" value="1" style="width:auto;"> Открытая группа
                    </label>
                    <button type="submit">Создать</button>
                </form>
            </div>

            <h2>Мои группы</h2>
            <div id="myGroups">
                <% if (myGroups && myGroups.length > 0) { %>
                    <% myGroups.forEach(function(group) { %>
                        <div class="group-card" onclick="window.location.href='/group/<%= group.id %>'">
                            <img src="<%= group.avatar || '/images/group_default.png' %>" alt="<%= group.name %>">
                            <div class="group-info">
                                <h3>
                                    <%= group.name %>
                                    <% if (group.is_public) { %>
                                        <span class="public-badge">Открытая</span>
                                    <% } else { %>
                                        <span class="private-badge">Закрытая</span>
                                    <% } %>
                                </h3>
                                <p>👥 <%= group.members_count %> участников</p>
                                <% if (group.creator_id == user.id) { %>
                                    <p class="creator-badge">👑 Вы создатель</p>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="color:#888;">Вы пока не состоите ни в одной группе</p>
                <% } %>
            </div>

            <h2>Открытые группы</h2>
            <div id="publicGroups">
                <% if (publicGroups && publicGroups.length > 0) { %>
                    <% publicGroups.forEach(function(group) { %>
                        <div class="group-card" onclick="window.location.href='/group/<%= group.id %>'">
                            <img src="<%= group.avatar || '/images/group_default.png' %>" alt="<%= group.name %>">
                            <div class="group-info">
                                <h3>
                                    <%= group.name %>
                                    <span class="public-badge">Открытая</span>
                                </h3>
                                <p>👥 <%= group.members_count %> участников</p>
                                <p>Создатель: <a href="/user/<%= group.creator_id %>"><%= group.creator_username %></a></p>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="color:#888;">Нет открытых групп</p>
                <% } %>
            </div>

            <% if (invites && invites.length > 0) { %>
                <div class="invites-section">
                    <h3>Приглашения в группы (<%= invites.length %>)</h3>
                    <% invites.forEach(function(invite) { %>
                        <div class="invite-item" id="invite-<%= invite.id %>">
                            <div>
                                <strong><%= invite.group_name %></strong>
                            </div>
                            <div>
                                <button class="accept-btn" onclick="handleInvite(<%= invite.id %>, 'accepted')">Принять</button>
                                <button class="reject-btn" onclick="handleInvite(<%= invite.id %>, 'rejected')">Отклонить</button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        async function handleInvite(inviteId, status) {
            try {
                const r = await fetch('/api/handle-invite', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ inviteId, status })
                });
                const d = await r.json();
                if (d.success) {
                    document.getElementById('invite-' + inviteId).remove();
                    if (status === 'accepted') {
                        alert('✅ Вы присоединились к группе!');
                        window.location.reload();
                    }
                } else {
                    alert(d.error || 'Ошибка');
                }
            } catch (e) {
                console.error(e);
            }
        }
    </script>
</body>
</html>
