<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Диалоги</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .dialogs-container {
            max-width: 800px;
            margin: 20px auto;
            background: rgba(0,0,0,0.5);
            border-radius: 10px;
            padding: 20px;
        }
        .dialog-item {
            display: flex;
            align-items: center;
            padding: 15px;
            border-bottom: 1px solid #555;
            cursor: pointer;
            transition: background 0.3s;
        }
        .dialog-item:hover { background: rgba(255,255,255,0.1); }
        .dialog-item img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            margin-right: 15px;
            object-fit: cover;
        }
        .dialog-info { flex: 1; }
        .dialog-info h3 { margin: 0 0 5px 0; color: #ff9900; }
        .dialog-info p { margin: 0; color: #ccc; font-size: 0.9em; }
        .dialog-time { color: #888; font-size: 0.8em; }
        .no-dialogs { text-align: center; padding: 40px; color: #888; }
    </style>
</head>
<body>
    <!-- БОКОВАЯ ПАНЕЛЬ -->
    <nav class="sidebar">
        <div class="sidebar-icon-logo">🛡️</div>
        <div class="sidebar-logo">HL2 Forum</div>
        
        <ul class="nav-list">
            <li class="nav-item">
                <a href="/" class="nav-link" data-tooltip="Главная">
                    <span class="nav-icon">🏠</span>
                    <span class="nav-text">Главная</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/new" class="nav-link create-btn" data-tooltip="Создать тему">
                    <span class="nav-icon">✏️</span>
                    <span class="nav-text">Создать тему</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/chat" class="nav-link" data-tooltip="Общий чат">
                    <span class="nav-icon">💬</span>
                    <span class="nav-text">Общий чат</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/groups" class="nav-link" data-tooltip="Группы">
                    <span class="nav-icon">👥</span>
                    <span class="nav-text">Группы</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/dialogs" class="nav-link active" data-tooltip="Диалоги">
                    <span class="nav-icon">📨</span>
                    <span class="nav-text">Диалоги</span>
                </a>
            </li>
            
            <div class="nav-divider"></div>
            
            <li class="nav-item">
                <a href="/user/<%= user.id %>" class="nav-link" data-tooltip="Профиль">
                    <span class="nav-icon">👤</span>
                    <span class="nav-text">Профиль</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/logout" class="nav-link logout-btn" data-tooltip="Выход">
                    <span class="nav-icon">🚪</span>
                    <span class="nav-text">Выход</span>
                </a>
            </li>
        </ul>
    </nav>
    <li class="nav-item">
    <a href="/support" class="nav-link" data-tooltip="Поддержка">
        <span class="nav-icon">🆘</span>
        <span class="nav-text">Поддержка</span>
    </a>
</li>
    <% if (['founder','admin','support','moderator'].includes(user.role)) { %>
        <li class="nav-item">
            <a href="/admin" class="nav-link" data-tooltip="Админ-панель" style="color: #ff9900;">
                <span class="nav-icon">⚙️</span>
                <span class="nav-text">Админ-панель</span>
            </a>
        </li>
    <% } %>

    <div class="container">
        <header>
            <h1><a href="/">Half-Life 2 Fan Forum</a></h1>
            <div class="user-menu">
                <img src="<%= user.avatar %>" width="30">
                <a href="/user/<%= user.id %>"><%= user.username %></a>
            </div>
        </header>

        <div class="dialogs-container">
            <h2>Ваши диалоги</h2>
            <div id="dialogs-list"></div>
        </div>
    </div>

    <script>
        fetch('/api/dialogs')
            .then(response => response.json())
            .then(dialogs => {
                const dialogsList = document.getElementById('dialogs-list');
                dialogsList.innerHTML = '';
                
                if (dialogs.length === 0) {
                    dialogsList.innerHTML = '<div class="no-dialogs">У вас пока нет диалогов.</div>';
                    return;
                }
                
                dialogs.forEach(dialog => {
                    const dialogElement = document.createElement('div');
                    dialogElement.className = 'dialog-item';
                    dialogElement.innerHTML = `
                        <img src="${dialog.avatar}" alt="${dialog.username}">
                        <div class="dialog-info">
                            <h3>${dialog.username}</h3>
                            <p>${dialog.content ? dialog.content.substring(0, 50) : 'Нет сообщений'}</p>
                        </div>
                        <div class="dialog-time">${new Date(dialog.created_at).toLocaleString()}</div>
                    `;
                    dialogElement.addEventListener('click', () => {
                        window.location.href = '/chat/' + dialog.dialog_user_id;
                    });
                    dialogsList.appendChild(dialogElement);
                
                 // ========== СИСТЕМА ГИФОК ==========
let gifVisible = false;

function toggleGifSearch() {
    gifVisible = !gifVisible;
    document.getElementById('gif-search').style.display = gifVisible ? 'block' : 'none';
    if (gifVisible) {
        document.getElementById('gif-query').focus();
    }
}

async function searchGifs() {
    const query = document.getElementById('gif-query').value.trim();
    if (!query) return;
    
    const API_KEY = 'aFFKTuSMjdC8SzMONUofN6e5WUO8WCn6';
    const url = `https://api.giphy.com/v1/gifs/search?api_key=${API_KEY}&q=${encodeURIComponent(query)}&limit=20&rating=pg-13&lang=ru`;
    
    document.getElementById('gif-results').innerHTML = '<div class="loading"></div>';
    
    try {
        const r = await fetch(url);
        const d = await r.json();
        const results = document.getElementById('gif-results');
        
        if (d.data.length === 0) {
            results.innerHTML = '<p style="color:#888;text-align:center;">Ничего не найдено 😔</p>';
            return;
        }
        
        results.innerHTML = d.data.map(g => `
            <div style="cursor:pointer;transition:0.3s;border-radius:8px;overflow:hidden;border:2px solid transparent;"
                 onmouseover="this.style.borderColor='#ff9900';this.style.transform='scale(1.05)'"
                 onmouseout="this.style.borderColor='transparent';this.style.transform='scale(1)'"
                 onclick="insertGif('${g.images.downsized.url.replace(/'/g, "\\'")}')">
                <img src="${g.images.fixed_height_small.url}" alt="${g.title}" style="height:80px;display:block;">
            </div>
        `).join('');
    } catch(e) {
        console.error('Ошибка загрузки гифок:', e);
        document.getElementById('gif-results').innerHTML = '<p style="color:#ff6b6b;">Ошибка загрузки 😢</p>';
    }
}

function insertGif(url) {
    // Для чатов - сразу отправляем
    const isChat = !!document.getElementById('messageInput');
    const isPrivateChat = !!document.getElementById('chatForm') && document.getElementById('messageInput');
    const isGroupChat = window.location.pathname.includes('/group/');
    const isTopicComment = !!document.querySelector('textarea[name="content"]');
    
    if (isGroupChat) {
        // Отправка гифки в группу
        const formData = new FormData();
        formData.append('groupId', groupId);
        formData.append('content', `<img src="${url}" style="max-width:100%;border-radius:8px;">`);
        formData.append('isGif', '1');
        
        fetch('/api/send-group-message', { method: 'POST', body: formData })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    document.getElementById('gif-search').style.display = 'none';
                    gifVisible = false;
                }
            });
    } else if (isPrivateChat) {
        // Отправка гифки в личку
        const formData = new FormData();
        formData.append('receiverId', receiver.id);
        formData.append('content', `<img src="${url}" style="max-width:100%;border-radius:8px;">`);
        
        fetch('/api/send-private-message', { method: 'POST', body: formData })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    document.getElementById('gif-search').style.display = 'none';
                    gifVisible = false;
                }
            });
    } else if (isTopicComment) {
        // Вставка гифки в текст комментария/темы
        const textarea = document.querySelector('textarea[name="content"]');
        textarea.value += `\n<img src="${url}" style="max-width:100%;border-radius:8px;">\n`;
        document.getElementById('gif-search').style.display = 'none';
        gifVisible = false;
    } else if (isChat) {
        // Общий чат - через Socket.io
        socket.emit('chat message', {
            userId: user.id,
            username: user.username,
            avatar: user.avatar,
            content: `<img src="${url}" style="max-width:100%;border-radius:8px;">`
        });
        document.getElementById('gif-search').style.display = 'none';
        gifVisible = false;
    }
}   
                });
            });
    </script>
</body>
</html>